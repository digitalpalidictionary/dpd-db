<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="utf-8">
        <meta data_key="data_{{ data.i.lemma_1_ }}">

        <title>Digital Pāḷi Dictionary</title>

        <style>
        </style>

        <link href="dpd-css-and-fonts.css" rel="stylesheet">

        <link href="family_compound_json.js" class="load_js" rel="preload"
            as="script">
        <link href="family_compound_template.js" class="load_js" rel="preload"
            as="script">
        <link href="family_idiom_json.js" class="load_js" rel="preload"
            as="script">
        <link href="family_idiom_template.js" class="load_js" rel="preload"
            as="script">
        <link href="family_root_json.js" class="load_js" rel="preload"
            as="script">
        <link href="family_root_template.js" class="load_js" rel="preload"
            as="script">
        <link href="family_set_json.js" class="load_js" rel="preload"
            as="script">
        <link href="family_set_template.js" class="load_js" rel="preload"
            as="script">
        <link href="family_word_json.js" class="load_js" rel="preload"
            as="script">
        <link href="family_word_template.js" class="load_js" rel="preload"
            as="script">
        <link href="feedback_template.js" class="load_js" rel="preload"
            as="script">
        <link href="frequency_template.js" class="load_js" rel="preload"
            as="script">
        <link href="main.js" class="load_js" rel="preload" as="script">

        <script>
        var data_{{ data.i.lemma_1_ }} = {
            "id": {{ data.i.id }},
            "lemma": "{{ data.i.lemma_1 }}",
            "date": "{{ data.date }}",
            "family_root": "{{ data.i.root_family_key }}",
            
            {% if data.i.needs_compound_family_button or data.i.needs_compound_families_button %}
            "family_compounds": [
                {%- for item in data.i.family_compound_list -%}
                '{{ item }}'{{ ", " if not loop.last }}
                {%- endfor -%}
            ],
            {% else %}
            "family_compounds": [],
            {% endif %}

            {% if data.i.needs_idioms_button %}
            "family_idioms": [
                {%- for item in data.i.family_idioms_list -%}
                '{{ item }}'{{ ", " if not loop.last }}
                {%- endfor -%}
            ],
            {% else %}
            "family_idioms": [],
            {% endif %}

            {% if data.i.needs_word_family_button %}
            "family_word": "{{ data.i.family_word }}",
            {% endif %}

            {% if data.i.needs_set_button or data.i.needs_sets_button %}
            "family_sets": [
                {%- for item in data.i.family_set_list -%}
                '{{ item }}'{{ ", " if not loop.last }}
                {%- endfor -%}
            ],
            {% else %}
            "family_sets": [],
            {% endif %}

            {% if data.i.needs_frequency_button %}
            "FreqHeading": "{{ data.i.freq_data_unpack["FreqHeading"] }}",
            "CstFreq": {{ data.i.freq_data_unpack["CstFreq"]|tojson }},
            "CstGrad": {{ data.i.freq_data_unpack["CstGrad"]|tojson }},
            "BjtFreq": {{ data.i.freq_data_unpack["BjtFreq"]|tojson }},
            "BjtGrad": {{ data.i.freq_data_unpack["BjtGrad"]|tojson }},
            "SyaFreq": {{ data.i.freq_data_unpack["SyaFreq"]|tojson }},
            "SyaGrad": {{ data.i.freq_data_unpack["SyaGrad"]|tojson }},
            "ScFreq": {{ data.i.freq_data_unpack["ScFreq"]|tojson }},
            "ScGrad": {{ data.i.freq_data_unpack["ScGrad"]|tojson }}
            {% endif %}
        };
    </script>

        <script>
        if (typeof progName == "undefined") {
            var progName = "GoldenDict"
        }
    </script>

        <script>
        var els2load = document.getElementsByClassName("load_js");
        if (typeof js_already_loaded === "undefined") {
            var js_already_loaded = true;
            var elsArray = Array.from(els2load);
            elsArray.forEach(el => {
                var s = document.createElement("script");
                var elName = el.getAttribute("href");
                s.src = elName;
                document.head.appendChild(s);
            });
        };
    </script>

    </head>
