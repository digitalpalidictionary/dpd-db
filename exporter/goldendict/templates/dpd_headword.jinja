    {% endif %}
    {% if d.i.needs_word_family_button %}
    <a class="dpd-button" href="#" data-target="family_word_{{ d.i.lemma_1_ }}">word family</a>
    {% endif %}
    {% if d.i.needs_compound_family_button %}
    <a class="dpd-button" href="#" data-target="family_compound_{{ d.i.lemma_1_ }}">compound family</a>
    {% elif d.i.needs_compound_families_button %}
    <a class="dpd-button" href="#" data-target="family_compound_{{ d.i.lemma_1_ }}">compound families</a>
    {% endif %}
    {% if d.i.needs_idioms_button %}
