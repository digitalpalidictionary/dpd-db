{% if d.i.needs_grammar_button %}
<div id="grammar_{{ d.i.lemma_1_ }}" class="dpd content hidden">
    <table class="grammar">
        <tr>
            <th>Lemma</th>
            <td>{{ d.i.lemma_clean }}</td>
        </tr>

        {% if d.i.lemma_trad_clean != d.i.lemma_clean %}
        <tr>
            <th>Traditional Lemma</th>
            <td>{{ d.i.lemma_trad_clean }}</td>
        </tr>
        {% endif %}

        <tr>
            <th>IPA</th>
            <td>
                /{{ d.i.lemma_ipa }}/
                {% if d.i.audio_male1 %}
                <a class="dpd-button play small" onclick="playAudio('{{ d.i.lemma_clean }}', this, 'male1')" data-title="male1">
                    <svg viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"></path>
                    </svg>
                </a>
                {% endif %}
                {% if d.i.audio_male2 %}
                <a class="dpd-button play small" onclick="playAudio('{{ d.i.lemma_clean }}', this, 'male2')" data-title="male2">
                    <svg viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"></path>
                    </svg>
                </a>
                {% endif %}
                {% if d.i.audio_female1 %}
                <a class="dpd-button play small" onclick="playAudio('{{ d.i.lemma_clean }}', this, 'female1')" data-title="female1">
                    <svg viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"></path>
                    </svg>
                </a>
                {% endif %}
            </td>
        </tr>

        <tr>
            <th>Grammar</th>
            <td>{{ d.grammar }}</td>
        </tr>

        {% if d.i.family_root %}
        <tr>
            <th>Root Family</th>
            <td>{{ d.i.family_root }}</td>
        </tr>
        {% endif %}
        {% if d.i.root_key %}
        <tr>
            <th>Root</th>
            <td>
                {{ d.i.root_clean }}<sup>{{ d.rt.root_has_verb }}</sup>{{ d.rt.root_group }}
                {{ d.i.root_sign }} ({{ d.rt.root_meaning }})
            </td>
        </tr>
        {% if d.rt.root_in_comps %}
        <tr>
            <th>√ In Sandhi</th>
            <td>{{ d.rt.root_in_comps }}</td>
        </tr>
        {% endif %}
        {% endif %}

        {% if d.i.root_base %}
        <tr>
            <th>Base</th>
            <td>{{ d.i.root_base }}</td>
        </tr>
        {% endif %}

        {% if d.i.construction %}
        <tr>
            <th>Construction</th>
            <td>{{ d.i.construction }}</td>
        </tr>
        {% endif %}

        {% if d.i.derivative %}
        <tr>
            <th>Derivative</th>
            <td>{{ d.i.derivative }} ({{ d.i.suffix }})</td>
        </tr>
        {% endif %}

        {% if d.i.phonetic %}
        <tr>
            <th>Phonetic Change</th>
            <td>{{ d.i.phonetic }}</td>
        </tr>
        {% endif %}

        {% if d.i.compound_type and "?" not in d.i.compound_type %}
        <tr>
            <th>Compound</th>
            <td>{{ d.i.compound_type }} ({{ d.i.compound_construction }})</td>
        </tr>
        {% endif %}

        {% if d.i.antonym %}
        <tr>
            <th>Antonym</th>
            <td>{{ d.i.antonym }}</td>
        </tr>
        {% endif %}

        {% if d.i.synonym %}
        <tr>
            <th>Synonym</th>
            <td>{{ d.i.synonym }}</td>
        </tr>
        {% endif %}

        {% if d.i.variant %}
        <tr>
            <th>Variant</th>
            <td>{{ d.i.variant }}</td>
        </tr>
        {% endif %}

        {% if d.i.commentary and d.i.commentary != "-" %}
        <tr>
            <th>Commentary</th>
            <td>{{ d.i.commentary }}</td>
        </tr>
        {% endif %}

        {% if d.i.notes %}
        <tr>
            <th>Notes</th>
            <td>{{ d.i.notes }}</td>
        </tr>
        {% endif %}

        {% if d.i.cognate %}
        <tr>
            <th>English Cognate</th>
            <td>{{ d.i.cognate }}</td>
        </tr>
        {% endif %}

        {% if d.i.link %}
        <tr>
            <th>Web Link</th>
            <td>
                {% for website in d.i.link_list %}
                <p style="margin: 0; padding: 0">
                    <a href="{{ website }}" target="_blank"> {{ website }} </a>
                </p>
                {% endfor %}
            </td>
        </tr>
        {% endif %}

        {% if d.i.non_ia %}
        <tr>
            <th>Non IA</th>
            <td><i>{{ d.i.non_ia }}</i></td>
        </tr>
        {% endif %}

        {% if d.i.sanskrit %}
        <tr>
            <th>Sanskrit</th>
            <td><i>{{ d.i.sanskrit }}</i></td>
        </tr>
        {% endif %}

        {% if d.i.root_key %}
        {% if d.rt.sanskrit_root and d.rt.sanskrit_root != "-" %}
        <tr>
            <th>Sanskrit Root</th>
            <td>
                <i>
                    {{ d.rt.sanskrit_root }} {{ d.rt.sanskrit_root_class }}
                    ({{ d.rt.sanskrit_root_meaning }})
                </i>
            </td>
        </tr>
        {% endif %}
        {% endif %}

    </table>
    <p class="dpd-footer">
        Did you spot a mistake?
        <a
            class="dpd-link"
            href="https://docs.google.com/forms/d/e/1FAIpQLSf9boBe7k5tCwq7LdWgBHHGIPVc4ROO5yjVDo1X5LDAxkmGWQ/viewform?usp=pp_url&entry.438735500={{ d.i.id }}%20{{ d.i.lemma_link }}&entry.326955045=Grammar&entry.1433863141=GoldenDict+{{ d.today }}"
            target="_blank">Correct it here</a>. <br />Is some word missing from
        the dictionary?
        <a
            class="dpd-link"
            href="https://docs.google.com/forms/d/e/1FAIpQLSfResxEUiRCyFITWPkzoQ2HhHEvUS5fyg68Rl28hFH6vhHlaA/viewform?usp=pp_url&entry.1433863141=GoldenDict+{{ d.today }}"
            target="_blank">Add it here</a>.
    </p>
</div>
{% endif %}

{% if d.i.needs_example_button or d.i.needs_examples_button %}
{% if d.i.example_1 and d.i.example_2 %}
<div id="examples_{{ d.i.lemma_1_ }}" class="dpd content hidden">
    {% elif d.i.example_1 and not d.i.example_2 %}
    <div id="example_{{ d.i.lemma_1_ }}" class="dpd content hidden">
        {% endif %}

        {% if d.i.example_1 %}
        <p>{{ d.i.example_1 }}</p>
        <p class="sutta">
            {{ d.i.source_1 }} {{ d.i.sutta_1 }}</p>
        {% endif %}

        {% if d.i.example_2 %}
        <p>
            {{ d.i.example_2 }}
        </p>
        <p class="sutta">
            {{ d.i.source_2 }} {{ d.i.sutta_2 }}
        </p>
        {% endif %}
        <p class='dpd-footer'>
            Can you think of a better example? <a class="dpd-link"
                href="https://docs.google.com/forms/d/e/1FAIpQLSf9boBe7k5tCwq7LdWgBHHGIPVc4ROO5yjVDo1X5LDAxkmGWQ/viewform?usp=pp_url&entry.438735500={{ d.i.id }}%20{{ d.i.lemma_link }}&entry.326955045=Examples&entry.1433863141=GoldenDict+{{ d.today }}"
                target="_blank">Add it here.</a>
        </p>
    </div>
{% endif %}

{% if d.i.needs_conjugation_button or d.i.needs_declension_button %}
{% if d.i.pos in d.declensions %}
<div id="declension_{{ d.i.lemma_1_ }}" class="dpd content hidden">
    {% elif d.i.pos in d.conjugations %}
    <div id="conjugation_{{ d.i.lemma_1_ }}" class="dpd content hidden">
        {% endif %}
        {{ d.i.inflections_html }}
        {% if "gray" in d.i.inflections_html %}
        <p>
            Inflections not found in any Pāḷi corpus, or within
            processed sandhi compounds are <span class='gray'>grayed out</span>.
            They might still occur within compounds.
        </p>
        <p class='dpd-footer'>
            {% else %}
            <p>
                {% endif %}
                {% if d.i.pos in d.declensions %}
                Did you spot a mistake in the declension table? Something
                missing? <a class="dpd-link"
                    href="https://docs.google.com/forms/d/e/1FAIpQLSfKUBx-icfRCWmhHqUwzX60BVQE21s_NERNfU2VvbjEfE371A/viewform?usp=pp_url&entry.1370304754={{ d.i.id }}%20{{ d.i.lemma_link }}&entry.1433863141=GoldenDict+{{ d.today }}"
                    target="_blank">Report it here.</a>
                {% elif d.i.pos in d.conjugations %}
                Did you spot a mistake in the conjugation table? Something
                missing? <a class="dpd-link"
                    href="https://docs.google.com/forms/d/e/1FAIpQLSdAL2PzavyrtXgGmtNrZAMyh3hV6g3fU0chxhWFxunQEZtH0g/viewform?usp=pp_url&entry.1932605469={{ d.i.id }}%20{{ d.i.lemma_link }}&entry.1433863141=GoldenDict+{{ d.today }}"
                    target="_blank">Report it here.</a>
                {% endif %}
            </p>
        </div>
{% endif %}

