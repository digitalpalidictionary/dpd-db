{{ d.header }}
<body>
<div class="dpd">
    <p>
        {{ d.i.pos }}. 
        {% if d.i.plus_case %}
        ({{ d.i.plus_case }}) 
        {% endif %}
        {{ d.i.meaning_combo_html }} 
        {% if d.i.construction_summary %}
        [{{ d.i.construction_summary }}] 
        {% endif %}
        {{ d.i.degree_of_completion_html }} 
        {% if d.show_id %}
        <span class="gray">{{ d.i.id }}</span>
        {% endif %}
    </p>
</div>
<div class="button-box">
    {% if d.i.needs_audio_button %}
    <a class="dpd-button play" onclick="playAudio('{{ d.i.lemma_clean }}', this)" title="Play Audio"><svg viewBox="0 0 24 24" width="16px" height="16px" fill="currentColor" stroke="currentColor" stroke-width="0"><path d="M8 5v14l11-7z"></path></svg></a>
    {% endif %}
    {% if d.i.needs_sutta_info_button %}
    <a class="dpd-button" href="#" data-target="sutta_info_{{ d.i.lemma_1_ }}">sutta</a>
    {% endif %}
    {% if d.i.needs_grammar_button %}
    <a class="dpd-button" href="#" data-target="grammar_{{ d.i.lemma_1_ }}">grammar</a>
    {% endif %}
    {% if d.i.needs_example_button %}
    <a class="dpd-button" href="#" data-target="example_{{ d.i.lemma_1_ }}">example</a>
    {% endif %}
    {% if d.i.needs_examples_button %}
    <a class="dpd-button" href="#" data-target="examples_{{ d.i.lemma_1_ }}">examples</a>
    {% endif %}
    {% if d.i.needs_conjugation_button %}
    <a class="dpd-button" href="#" data-target="conjugation_{{ d.i.lemma_1_ }}">conjugation</a>
    {% endif %}
    {% if d.i.needs_declension_button %}
    <a class="dpd-button" href="#" data-target="declension_{{ d.i.lemma_1_ }}">declension</a>
    {% endif %}
    {% if d.i.needs_root_family_button %}
