<idx:entry name="Pali" scriptable="yes" spell="yes" id="{{ counter }}">
    <idx:short>
        <idx:orth value="{{ construction }}"><b>{{ construction }}</b>
            {% if script_inflections %}
            <idx:infl>
                {% for inflection in script_inflections %}
                <idx:iform value="{{ inflection }}" exact="yes"></idx:iform>
                {% endfor %}
            </idx:infl>
            {% endif %}
        </idx:orth>
        <p class="body-space">{{ deconstruction }}</p>
    </idx:short>
</idx:entry>
<hr class="dpd" />
